#!/bin/sh

set -eu

changed_sql_files=$(git diff --cached --name-only --diff-filter=DMCRTUXB -- '*.sql')

if [ -n "$changed_sql_files" ]; then
	echo "Existing SQL files must not be modified, deleted, copied, renamed, or type-changed." >&2
	echo "Create a new migration file instead." >&2
	echo "$changed_sql_files" >&2
	exit 1
fi
